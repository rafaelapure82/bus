  pick_location_id                              Int
  drop_location_id                              Int
  pick_stand_id                                 Int
  drop_stand_id                                 Int
  price                                         String
  discount                                      String?
  roundtrip_discount                            String?
  totaltax                                      String?
  paidamount                                    String
  offerer                                       String?
  adult                                         String?
  chield                                        String?
  special                                       String?
  seatnumber                                    String
