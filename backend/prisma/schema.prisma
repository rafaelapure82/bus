  updated_at                                    DateTime? @default(now())
  deleted_at                                    DateTime?
  users_tickets_bookby_user_idTousers           users     @relation("tickets_bookby_user_idTousers", fields: [bookby_user_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  locations_tickets_drop_location_idTolocations locations @relation("tickets_drop_location_idTolocations", fields: [drop_location_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  pickdrops_tickets_drop_stand_idTopickdrops    pickdrops @relation("tickets_drop_stand_idTopickdrops", fields: [drop_stand_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  users_tickets_passanger_idTousers             users     @relation("tickets_passanger_idTousers", fields: [passanger_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  locations_tickets_pick_location_idTolocations locations @relation("tickets_pick_location_idTolocations", fields: [pick_location_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  pickdrops_tickets_pick_stand_idTopickdrops    pickdrops @relation("tickets_pick_stand_idTopickdrops", fields: [pick_stand_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  subtrips                                      subtrips  @relation(fields: [subtrip_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  trips                                         trips     @relation(fields: [trip_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  vehicles                                      vehicles  @relation(fields: [vehicle_id], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([bookby_user_id])
  @@index([drop_location_id])
  @@index([drop_stand_id])
  @@index([passanger_id])
  @@index([pick_location_id])
  @@index([pick_stand_id])
  @@index([subtrip_id])
  @@index([trip_id])
  @@index([vehicle_id])
}

